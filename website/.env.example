# Copy to `.env` for local dev. Production CI should set this variable before `npm run build`.

# Required for correct sitemap.xml, robots.txt, canonical URLs, and Open Graph at `next build`.
# Use the hostname you want Google to treat as primary (www or apex — pick one).
NEXT_PUBLIC_SITE_URL=https://www.autoconnecto.in

# Optional — paste the content value from Google Search Console → HTML tag method only (not the whole tag).
# Rebuild and redeploy `out/` after setting. Example: NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=AbCdEf123...
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
